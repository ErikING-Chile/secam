# Edge Agent Environment Variables

# Cloud API URL
CLOUD_API_URL=http://localhost:8000

# Edge Agent credentials (obtain from cloud dashboard)
EDGE_AGENT_ID=your_agent_id_here
EDGE_AGENT_SECRET=your_agent_secret_here

# Processing settings (in seconds)
FRAME_INTERVAL=5

# Face recognition thresholds
FACE_DETECTION_THRESHOLD=0.6
FACE_RECOGNITION_THRESHOLD=0.6

# Storage path for snapshots
STORAGE_PATH=/tmp/secam/faces
