# Secam Environment Variables

# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
POSTGRES_PASSWORD=change_this_secure_password_123

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_in_production_with_secure_random_string

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# API CONFIGURATION
# ============================================
DATABASE_URL=postgresql://secam:POSTGRES_PASSWORD@localhost:5432/secam
REDIS_URL=redis://localhost:6380

ENVIRONMENT=development
DEBUG=true

# ============================================
# NETWORK (for access from other machines)
# ============================================
# Set your server IP here for external access
# Change from localhost to your machine's IP (e.g., 192.168.1.100)
SERVER_IP=localhost

# Frontend URLs - Update these with your SERVER_IP
# Replace localhost with your IP address
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ============================================
# SECURITY
# ============================================
# Fernet key for encrypting RTSP URLs
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_this_encryption_key

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# ============================================
# NOTIFICATIONS (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secam.io

TELEGRAM_BOT_TOKEN=

# ============================================
# AI/ML CONFIGURATION
# ============================================
AI_MODEL_PATH=/app/models
FACE_DETECTION_THRESHOLD=0.6
FACE_RECOGNITION_THRESHOLD=0.6

# ============================================
# STORAGE
# ============================================
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=10

# ============================================
# EDGE AGENT (Optional)
# ============================================
EDGE_AGENT_ID=
EDGE_AGENT_SECRET=
CLOUD_API_URL=http://localhost:8000
